# Keep the image clean and — critically — keep confidential data / keys OUT.
.git
.gitignore
__pycache__/
**/__pycache__/
*.pyc
*.pyo

# Never ship real credentials or internal deal configs — shared_settings.json is
# regenerated from Space Secrets at startup by docker-entrypoint.sh.
configs/
output/
Input_files/
offline_packages/

# Generated caches (rebuilt at runtime from the GeoJSON, which IS shipped)
backend/data/_landuse_buckets.pkl
backend/data/_onemap_tourism.json

# Docs / local cruft not needed in the image
DEPLOY.md
tmp*.json
*.log
.DS_Store
.streamlit/
